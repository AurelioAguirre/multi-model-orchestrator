# LLM Tensor Server Environment Configuration

# Application Environment Mode
# - mock: Uses mock TensorRT service for development/testing
# - dev:  Development mode with all engines (Transformers, vLLM, TensorRT)  
# - prod: Production mode (same as dev for now, can be customized later)
APP_ENVIRONMENT=dev

# CUDA Configuration
CUDA_VISIBLE_DEVICES=0,1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Model Storage
HF_HOME=./models

# Logging
LOG_LEVEL=INFO

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8011

# Mock Service Configuration (when APP_ENVIRONMENT=mock)
MOCK_TENSORRT_PORT=8012