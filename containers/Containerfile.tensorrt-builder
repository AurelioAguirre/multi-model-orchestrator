# TensorRT-LLM Engine Builder Podmanfile
# Builds TensorRT engines from HuggingFace models
# Uses same CUDA/library versions as inference pod

# CUDA 12.9 base for TensorRT-LLM 1.0.0 stable
FROM docker.io/nvidia/cuda:12.9.0-cudnn-devel-ubuntu24.04

# Set timezone
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# Install Python 3.12 and system dependencies
RUN apt-get update && apt-get install -y \
    software-properties-common \
    wget \
    curl \
    git \
    build-essential \
    openmpi-bin \
    openmpi-common \
    libopenmpi-dev \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y python3.12 python3.12-dev python3.12-venv \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Set Python 3.12 as default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1 && \
    update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1

# Install pip for Python 3.12 using get-pip.py (break-system-packages is safe in containers)
RUN wget https://bootstrap.pypa.io/get-pip.py && \
    python3.12 get-pip.py --break-system-packages && \
    rm get-pip.py

# Set working directory
WORKDIR /app

# Copy requirements for TensorRT-LLM 1.0.0 stable
COPY requirements/podman/tensorrt_cuda129_compatible.txt /app/requirements/tensorrt.txt

# Install TensorRT-LLM 1.0.0 stable from PyPI with PyTorch cu128
# (break-system-packages is safe in containers)
RUN pip install --no-cache-dir --break-system-packages --upgrade pip setuptools wheel && \
    pip install --no-cache-dir --break-system-packages --extra-index-url https://download.pytorch.org/whl/cu128 -r requirements/tensorrt.txt

# Copy build scripts
COPY src/tensorrt/builder/ /app/src/tensorrt/builder/
COPY resources/ /app/resources/

# Create directories
RUN mkdir -p /app/models
RUN mkdir -p /app/models/tensorrt-engines

# Set environment variables
ENV PYTHONPATH=/app
ENV HF_HOME=/app/models
ENV CUDA_MODULE_LOADING=LAZY
ENV TORCH_CUDA_ARCH_LIST=8.9

# Default command runs the builder script
CMD ["python", "/app/src/tensorrt/builder/build_engines.py"]